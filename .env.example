# Admin web UI password
ADMIN_PASSWORD=changeme

# Secret key for session cookies (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=replace-with-a-long-random-string

# Per-consumer secrets Tempus / Munus each send as the `X-API-Key` header to read the
# roster and hit /sso/challenge. Generate one for each with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Both blank = the read API is disabled (returns 503).
TEMPUS_API_KEY=
MUNUS_API_KEY=

# SQLite database file path
DATABASE_URL=sqlite+aiosqlite:///./legion.db

# Timezone, e.g. America/New_York
TIMEZONE=America/New_York

# Slack profile sync — pushes team / school year / focus group / guardian data into
# each member's Slack custom profile fields (nightly job + a manual admin button).
# Requires an ADMIN user token (xoxp-…) with users.profile:write to edit *other*
# users' profiles; a normal bot token can only edit its own. Blank = sync disabled.
SLACK_BOT_TOKEN=
SLACK_SYNC_TIME=01:00
SLACK_SYNC_DAY=*

# Database backups (SQLite only)
BACKUP_DIR=backups
BACKUP_KEEP=14
BACKUP_TIME=23:30
BACKUP_DAY=sun

# Master switch for scheduled jobs (currently the nightly backup)
UPDATES_ENABLED=true

# ── SSO ──────────────────────────────────────────────────────────────────────
# Legion is the SSO provider for the MARS/WARS apps. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SSO_SECRET=replace-with-a-long-random-string

# Cookie domain so the mw_sso cookie is shared across every subdomain, e.g.
# ".marswars.org". Blank = host-only cookie (fine for local dev).
SSO_COOKIE_DOMAIN=

SSO_SESSION_TTL=43200
SSO_CHALLENGE_TTL=30
# Longer TTL for challenges started server-to-server via POST /sso/challenge (e.g.
# Munus's /vhours one-tap link) — there's a human-reads-a-Slack-message delay before any
# browser starts polling, unlike the form flow above where the tab is already open.
SSO_API_CHALLENGE_TTL=300

# Login rate limit / exponential backoff (per browser + per member).
SSO_RATE_MAX=3
SSO_RATE_WINDOW=300
SSO_BACKOFF_BASE=30
SSO_BACKOFF_MULTIPLIER=4

# Comma-separated hostnames /sso/authorize is allowed to redirect back to.
SSO_ALLOWED_RETURN_HOSTS=localhost,127.0.0.1

# Absolute base URL of this Legion instance.
BASE_URL=http://localhost:8002

# Slack app for SSO: DMs the Approve/Deny push and receives the button click.
# Needs a BOT token (xoxb-…, scopes chat:write + im:write) — NOT the admin user
# token SLACK_BOT_TOKEN holds above — plus the app's signing secret. Blank =
# SSO Slack challenges are disabled.
SLACK_AUTH_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Public URLs for the sibling apps' tiles on Legion's signed-in home page ("/").
# Blank = that app's tile is omitted. Not the same as the internal Docker-network
# addresses used elsewhere (tempus_interact_url etc.) — these must be resolvable
# from a member's own browser.
TEMPUS_PUBLIC_URL=https://tempus.example.org
MUNUS_PUBLIC_URL=https://munus.example.org
